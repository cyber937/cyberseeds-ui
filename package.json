  "scripts": {
    "dev": "vite",
    "build:css:preview": "tailwindcss -i ./src/index.css -o ./src/style.css --minify",
    "build:css": "tailwindcss -i ./src/index-dist.css -o ./dist/style.css --minify",
    "build": "npm run build:css:preview && tsc -b && vite build && npm run build:css",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:storybook": "vitest --config vitest.config.ts",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:deploy": "gh-pages -d storybook-static"
